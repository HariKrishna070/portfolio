# EmailJS credentials – NEVER commit real values here, this file IS committed to git
# Copy this file as .env.local and fill in your real values there
# Vite requires all client-side env vars to be prefixed with VITE_

VITE_EMAILJS_SERVICE_ID=YOUR_SERVICE_ID
VITE_EMAILJS_TEMPLATE_ID=YOUR_TEMPLATE_ID
VITE_EMAILJS_PUBLIC_KEY=YOUR_PUBLIC_KEY